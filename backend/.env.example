# Browser-accessible Casdoor origin. Kerberos requires the DNS hostname, not an IP address.
CASDOOR_ENDPOINT=http://casdoor.lab.hexcode.test:8080

# Dedicated Casdoor application name and OAuth/OIDC credentials.
CASDOOR_APPLICATION=app-svelte-litestar
CASDOOR_CLIENT_ID=replace-with-casdoor-client-id
CASDOOR_CLIENT_SECRET=replace-with-casdoor-client-secret

# Must exactly match a Redirect URL configured on the Casdoor application.
CASDOOR_REDIRECT_URI=http://WINDOWS_SERVER_HOST:9090/api/auth/callback
CASDOOR_SCOPE=openid profile email

# Optional endpoint overrides. The defaults are derived from CASDOOR_ENDPOINT.
CASDOOR_KERBEROS_URL=
CASDOOR_TOKEN_URL=

# Optional token validation settings.
CASDOOR_AUDIENCE=
CASDOOR_DISCOVERY_URL=
CASDOOR_ALLOWED_ALGORITHMS=RS256

# Application session and local fallback account storage.
AUTH_DATABASE_PATH=data/auth.db
SESSION_TTL_SECONDS=28800
AUTH_FLOW_TTL_SECONDS=300

# Keep false for the current internal HTTP test. Set true when the app uses HTTPS.
SESSION_COOKIE_SECURE=false
